# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_dev_guild_id_optional
ADMIN_ROLE_ID=your_admin_role_id
VIP_ROLE_ID=your_vip_role_id
ALERT_DISCORD_CHANNEL_ID=channel_id_for_offline_alerts

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000
API_SECRET_KEY=change_this_to_a_long_random_secret
API_BASE_URL=http://api:3000

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=pterodactyl_bot
DB_USER=botuser
DB_PASSWORD=change_this_db_password
DB_ROOT_PASSWORD=change_this_root_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ── Pterodactyl ───────────────────────────────────────────────────────────────
PTERODACTYL_URL=https://panel.yourdomain.com
PTERODACTYL_APP_API_KEY=ptla_APPLICATION_KEY_HERE
PTERODACTYL_CLIENT_API_KEY=ptlc_CLIENT_KEY_HERE

# Pterodactyl resource IDs (get from your panel)
PTERO_DEFAULT_NODE_ID=1
PTERO_DEFAULT_NEST_ID=1
PTERO_MINECRAFT_EGG_ID=1
PTERO_RUST_EGG_ID=2
PTERO_TERRARIA_EGG_ID=3

# Resource limits
MINECRAFT_MEMORY=2048
MINECRAFT_DISK=10240
MINECRAFT_CPU=100

RUST_MEMORY=4096
RUST_DISK=20480
RUST_CPU=200

TERRARIA_MEMORY=1024
TERRARIA_DISK=5120
TERRARIA_CPU=100

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITOR_POLL_INTERVAL_MS=30000
LOG_LEVEL=info
