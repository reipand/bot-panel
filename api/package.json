{
  "name": "pterodactyl-bot-api",
  "version": "1.0.0",
  "description": "Express API layer for Pterodactyl Discord bot",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
