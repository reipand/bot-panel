NODE_ENV=production
PORT=3000

# Internal API security
API_SECRET_KEY=generate_a_long_random_secret_here

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pterodactyl_bot
DB_USER=botuser
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Pterodactyl
PTERODACTYL_URL=https://panel.yourdomain.com
PTERODACTYL_APP_API_KEY=ptla_your_application_api_key
PTERODACTYL_CLIENT_API_KEY=ptlc_your_client_api_key

# Pterodactyl deployment defaults
PTERO_DEFAULT_NODE_ID=1
PTERO_DEFAULT_ALLOCATION_ID=1
PTERO_MINECRAFT_EGG_ID=1
PTERO_RUST_EGG_ID=2
PTERO_TERRARIA_EGG_ID=3
PTERO_DEFAULT_NEST_ID=1

# Resource limits per server type (MB/MB/%/disk MB)
MINECRAFT_MEMORY=2048
MINECRAFT_DISK=10240
MINECRAFT_CPU=100

RUST_MEMORY=4096
RUST_DISK=20480
RUST_CPU=200

TERRARIA_MEMORY=1024
TERRARIA_DISK=5120
TERRARIA_CPU=100

# Monitoring
MONITOR_POLL_INTERVAL_MS=30000
ALERT_DISCORD_CHANNEL_ID=your_alert_channel_id
DISCORD_BOT_TOKEN=your_discord_bot_token_for_alerts
